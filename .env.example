# x402-mica Phase 1 config. Copy to .env and fill in PAY_TO.

# Network (CAIP-2): eip155:84532 = Base Sepolia (dev), eip155:8453 = Base mainnet
X402_NETWORK=eip155:84532

# Facilitator URL for testnet. Leave default for the open x402.org facilitator.
X402_FACILITATOR_URL=https://x402.org/facilitator

# Seller wallet that receives payment (required)
PAY_TO=0xYourSellerAddress

PRICE=$0.01

# Settlement asset: USDC (default) or EURC. For EURC use a plain euro PRICE, e.g. PRICE=0.01
X402_ASSET=USDC
PORT=3000
DB_PATH=./audit.db

# Set to enable the read-only audit dashboard at GET /audit (unset => 503).
# Pass as `x-api-key` header or `?key=` query param.
AUDIT_API_KEY=

# Mainnet only (X402_NETWORK=eip155:8453): Coinbase CDP hosted facilitator keys
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
