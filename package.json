{
  "name": "x402-mica",
  "version": "0.1.0",
  "description": "EU-facing x402 payment middleware with MiCA-compliance audit logging — Express middleware, MCP tool decorator, and audit dashboard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iCx6/x402-mica.git"
  },
  "homepage": "https://github.com/iCx6/x402-mica#readme",
  "bugs": {
    "url": "https://github.com/iCx6/x402-mica/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "x402",
    "mica",
    "micropayments",
    "usdc",
    "stablecoin",
    "express",
    "middleware",
    "mcp",
    "audit"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "client": "tsx src/client.ts",
    "mcp": "tsx src/mcp-example.ts",
    "mcp-client": "tsx src/mcp-client.ts",
    "test": "tsx src/audit.test.ts && tsx src/dashboard.test.ts && tsx src/assets.test.ts",
    "prepack": "npm run build && npm test"
  },
  "dependencies": {
    "@coinbase/x402": "2.1.0",
    "@x402/core": "2.17.0",
    "@x402/evm": "^2.17.0",
    "@x402/express": "2.17.0",
    "@x402/mcp": "^2.17.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@x402/fetch": "^2.17.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "viem": "^2.54.1",
    "zod": "^3.25.76"
  }
}
